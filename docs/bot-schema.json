{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ArenaFramework Bot Protocol",
  "description": "JSON Schema for NDJSON messages between ArenaFramework and bots.",
  "oneOf": [
    {
      "title": "ServerMessage (Host -> Bot)",
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "enum": ["start", "state", "end"],
          "description": "Initial handshake, game state update, or game termination."
        },
        "state": {
          "description": "Game-specific state data (opaque JSON payload)."
        },
        "axes": {
          "type": "array",
          "description": "Axis definitions sent during 'start' phase.",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "value": { "type": "number" }
            },
            "required": ["name", "value"]
          }
        }
      },
      "required": ["type"]
    },
    {
      "title": "InputMessage (Bot -> Host)",
      "type": "object",
      "properties": {
        "axes": {
          "type": "object",
          "description": "Set axis values (range -1.0 to 1.0).",
          "additionalProperties": {
            "type": "number"
          }
        }
      },
      "required": ["axes"]
    }
  ]
}
